{
  "name": "console-highlighter",
  "displayName": "Console Highlighter",
  "description": "Highlight console.log, console.error, console.warn, console.info, and console.debug statements with different colors",
  "version": "0.0.2",
  "publisher": "sheik-mostafizur",
  "author": {
    "name": "Sheik Mostafizur",
    "email": "sheikmostafizur2001@gmail.com"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sheik-mostafizur/console-highlighter"
  },
  "homepage": "https://github.com/sheik-mostafizur/console-highlighter/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/sheik-mostafizur/console-highlighter/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "console",
    "highlight",
    "debug",
    "log",
    "console.log",
    "console.error",
    "javascript",
    "typescript"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Console Highlighter",
      "properties": {
        "consoleHighlighter.colors": {
          "type": "object",
          "properties": {
            "log": {
              "type": "string",
              "default": "rgba(0, 255, 106, 1)",
              "description": "Color for console.log"
            },
            "info": {
              "type": "string",
              "default": "rgba(56, 189, 248, 1)",
              "description": "Color for console.info"
            },
            "warn": {
              "type": "string",
              "default": "rgba(251, 191, 36, 1)",
              "description": "Color for console.warn"
            },
            "error": {
              "type": "string",
              "default": "rgba(248, 113, 113, 1)",
              "description": "Color for console.error"
            },
            "debug": {
              "type": "string",
              "default": "rgba(167, 139, 250, 1)",
              "description": "Color for console.debug"
            },
            "dir": {
              "type": "string",
              "default": "rgba(148, 163, 184, 1)",
              "description": "Color for console.dir"
            }
          },
          "default": {
            "log": "rgba(0, 255, 106, 1)",
            "info": "rgba(56, 189, 248, 1)",
            "warn": "rgba(251, 191, 36, 1)",
            "error": "rgba(248, 113, 113, 1)",
            "debug": "rgba(167, 139, 250, 1)",
            "dir": "rgba(148, 163, 184, 1)"
          },
          "description": "Colors for different console methods"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm install",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.8.0",
    "vsce": "^2.15.0"
  }
}
